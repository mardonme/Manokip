# TEST BRANCH — Neon test-branch values for Vitest integration + Playwright e2e
# Copy this to .env.test (gitignored) and fill in real test-branch credentials.

# Neon test branch (eu-central-1) — pooled runtime + direct migration
DATABASE_URL=postgresql://neondb_owner:***@ep-xxx-test-pooler.eu-central-1.aws.neon.tech/neondb?sslmode=require
DATABASE_URL_DIRECT=postgresql://neondb_owner:***@ep-xxx-test.eu-central-1.aws.neon.tech/neondb?sslmode=require

# Auth.js — use a dedicated test secret (not production)
AUTH_SECRET=test-secret-at-least-thirty-two-chars-xxxxxxxxxx
AUTH_RESEND_KEY=re_test_xxx
RESEND_FROM_EMAIL=test@manometr.uz

# Bootstrap admin for e2e magic-link round-trip
BOOTSTRAP_ADMIN_EMAIL=test-admin@manometr.uz

# Cloudinary test subaccount — DO NOT use production secrets
CLOUDINARY_CLOUD_NAME=manometr-test
CLOUDINARY_API_KEY=xxx
CLOUDINARY_API_SECRET=xxx

# Sentry (optional for tests)
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
NEXT_PUBLIC_SENTRY_DSN=

# Playwright target — defaults to http://localhost:3000 if unset
TEST_BASE_URL=http://localhost:3000
