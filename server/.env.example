# PostgreSQL connection string (Render gives you this when you create a DB).
# Local example: postgresql://postgres:postgres@localhost:5432/manokip
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME"

# Render sets PORT automatically; leave unset there.
PORT=4000

# Long random string. Generate one: `openssl rand -hex 64`
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN="7d"

# Comma-separated list of allowed frontend origins (no trailing slash).
# In production set this to your Vercel URL(s):
#   CORS_ORIGIN="https://your-app.vercel.app,https://www.your-domain.com"
CORS_ORIGIN="http://localhost:5173"

# Seed admin user
ADMIN_EMAIL="admin@manokip.local"
ADMIN_PASSWORD="admin1234"

# "production" on Render, "development" locally
NODE_ENV="development"
