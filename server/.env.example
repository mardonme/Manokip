# PostgreSQL connection string (Render gives you this when you create a DB).
# Local example: postgresql://postgres:postgres@localhost:5432/manokip
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME"

# Render sets PORT automatically; leave unset there.
PORT=4000

# Long random string. Generate one: `openssl rand -hex 64`
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN="7d"

# Comma-separated list of allowed frontend origins (no trailing slash).
# In production set this to your Vercel URL(s):
#   CORS_ORIGIN="https://your-app.vercel.app,https://www.your-domain.com"
CORS_ORIGIN="http://localhost:5173"

# Seed admin user
ADMIN_EMAIL="admin@manokip.local"
ADMIN_PASSWORD="admin1234"

# "production" on Render, "development" locally
NODE_ENV="development"

# --- Telegram admin notifications (so'rovnoma / zakaz) ---
# Bot token from @BotFather. When unset, notifications are silently skipped.
BOT_TOKEN=""
# The admin chat id to notify. To find it: start the server, open your bot in
# Telegram and send /start — the bot replies with your chat id. Paste it here.
ADMIN_CHAT_ID=""
# Set to "false" to disable the /start chat-id helper poller (e.g. if you run
# multiple server instances or use a webhook instead).
TELEGRAM_POLLING="true"

# --- AI assistant (Gemini) ---
# Get a free key at https://aistudio.google.com (no credit card required).
# When unset, /api/chat replies with an operator-handoff fallback.
GEMINI_API_KEY=""
# Model id. gemini-2.5-flash works on the current free tier. Alternatives:
# gemini-2.5-flash-lite (cheaper/faster), gemini-2.5-pro (smarter, pricier).
GEMINI_MODEL="gemini-2.5-flash"
